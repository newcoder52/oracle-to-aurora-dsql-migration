{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInsecureTransport",
      "Effect": "Deny",
      "Principal": {
        "AWS": [
          "arn:aws:iam::ACCOUNT_ID:role/DMSRole",
          "arn:aws:iam::ACCOUNT_ID:role/GlueJobRole"
        ]
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::your-migration-bucket",
        "arn:aws:s3:::your-migration-bucket/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    }
  ]
}